{
  "name": "diesel-monitor",
  "description": "Дизель Монітор UA — ціни на дизельне пальне в Україні: дашборд у стилі фінансового термінала",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "lint": "oxlint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "preview": "vite preview",
    "collect": "node scripts/collect.mjs",
    "backfill": "node scripts/backfill.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "echarts": "^6.1.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.6",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
